<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
<title>Flowchart Creator</title>
<style>
:root{color-scheme:light;--bg:#f4f7fb;--panel:#ffffff;--panel-2:#f8fafc;--text:#111827;--muted:#687385;--line:#d7dee9;--line-strong:#aeb8c8;--accent:#2563eb;--accent-2:#1d4ed8;--danger:#dc2626;--shadow:0 18px 50px rgba(17,24,39,.11);--soft:0 10px 24px rgba(15,23,42,.08);--input:#ffffff;--grid:rgba(37,99,235,.08);--canvas:#eef3fa;--selected:#2563eb;--marquee:rgba(37,99,235,.12);--marquee-border:rgba(37,99,235,.75)}
[data-theme="dark"]{color-scheme:dark;--bg:#0b1220;--panel:#111827;--panel-2:#151f31;--text:#eef2ff;--muted:#a9b4c7;--line:#273449;--line-strong:#3c4a62;--accent:#60a5fa;--accent-2:#3b82f6;--danger:#f87171;--shadow:0 18px 50px rgba(0,0,0,.34);--soft:0 12px 28px rgba(0,0,0,.25);--input:#0e1728;--grid:rgba(147,197,253,.09);--canvas:#0e1726;--selected:#93c5fd;--marquee:rgba(96,165,250,.15);--marquee-border:rgba(147,197,253,.85)}
*{box-sizing:border-box}html,body{height:100%;margin:0;overflow:hidden;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--bg);color:var(--text)}button,input,select,textarea{font:inherit}button{border:0;cursor:pointer;color:inherit}button:disabled{opacity:.45;cursor:not-allowed}.app{height:100%;display:grid;grid-template-rows:58px 1fr}.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid var(--line);background:var(--panel);box-shadow:0 1px 0 rgba(0,0,0,.02);z-index:5}.brand{display:flex;align-items:center;gap:12px;min-width:0}.mark{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(--accent),#8b5cf6);box-shadow:0 10px 24px rgba(37,99,235,.24);position:relative;flex:0 0 auto}.mark:before,.mark:after{content:"";position:absolute;background:#fff;border-radius:999px}.mark:before{width:15px;height:5px;left:8px;top:9px}.mark:after{width:10px;height:10px;right:7px;bottom:7px}.title-wrap{min-width:0;display:flex;align-items:center;gap:10px}.chart-title{width:min(380px,38vw);border:1px solid transparent;border-radius:10px;background:transparent;color:var(--text);font-size:16px;font-weight:700;padding:8px 10px;outline:none}.chart-title:hover,.chart-title:focus{border-color:var(--line);background:var(--panel-2)}.status{font-size:12px;color:var(--muted);white-space:nowrap}.top-actions{display:flex;align-items:center;gap:8px}.btn{height:36px;padding:0 12px;border-radius:10px;background:var(--panel-2);border:1px solid var(--line);display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:650;box-shadow:0 1px 0 rgba(255,255,255,.05)}.btn:hover{border-color:var(--line-strong);transform:translateY(-1px)}.btn.primary{background:var(--accent);border-color:var(--accent-2);color:white}.btn.danger{color:var(--danger)}.layout{min-height:0;display:grid;grid-template-columns:272px 1fr 318px}.sidebar,.props{background:var(--panel);border-right:1px solid var(--line);min-height:0;overflow:auto}.props{border-right:0;border-left:1px solid var(--line)}.section{padding:16px;border-bottom:1px solid var(--line)}.section h2{font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin:0 0 12px}.tool-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.tool-grid .btn{justify-content:center;width:100%}.charts{display:flex;flex-direction:column;gap:8px}.chart-row{display:grid;grid-template-columns:1fr auto;gap:6px;align-items:center;padding:10px;border:1px solid var(--line);border-radius:12px;background:var(--panel-2)}.chart-row.active{border-color:var(--accent);box-shadow:0 0 0 3px color-mix(in srgb,var(--accent) 18%,transparent)}.chart-name{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.chart-meta{font-size:11px;color:var(--muted);margin-top:3px}.mini-actions{display:flex;gap:4px}.icon-btn{width:30px;height:30px;border-radius:9px;background:transparent;border:1px solid transparent;color:var(--muted)}.icon-btn:hover{background:var(--panel);border-color:var(--line);color:var(--text)}.hint{font-size:12px;line-height:1.55;color:var(--muted);margin:0}.workspace{position:relative;min-width:0;min-height:0;background:var(--canvas)}#stage{position:absolute;inset:0;width:100%;height:100%;display:block;cursor:crosshair}.workspace.panning #stage{cursor:grabbing}.workspace.connecting #stage{cursor:copy}.floating{position:absolute;left:18px;bottom:18px;display:flex;gap:10px;align-items:center;padding:10px 12px;border-radius:14px;background:color-mix(in srgb,var(--panel) 92%,transparent);border:1px solid var(--line);box-shadow:var(--soft);backdrop-filter:blur(14px);font-size:12px;color:var(--muted);pointer-events:none}.zoom-pill{font-weight:800;color:var(--text)}.mode-pill{position:absolute;top:18px;left:50%;transform:translateX(-50%);padding:10px 14px;border-radius:999px;background:var(--accent);color:white;font-size:13px;font-weight:750;box-shadow:var(--soft);display:none}.workspace.connecting .mode-pill{display:block}.field{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}.field label{font-size:12px;font-weight:750;color:var(--muted)}.field input,.field select,.field textarea{width:100%;border:1px solid var(--line);background:var(--input);color:var(--text);border-radius:10px;padding:9px 10px;outline:none}.field textarea{min-height:92px;resize:vertical;line-height:1.4}.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px color-mix(in srgb,var(--accent) 18%,transparent)}.row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.empty{padding:20px;border:1px dashed var(--line-strong);border-radius:14px;background:var(--panel-2);color:var(--muted);font-size:13px;line-height:1.5}.kbd{display:inline-flex;align-items:center;justify-content:center;min-width:22px;height:20px;border-radius:5px;border:1px solid var(--line-strong);font-size:11px;color:var(--text);background:var(--panel);box-shadow:inset 0 -1px 0 rgba(0,0,0,.08)}.divider{height:1px;background:var(--line);margin:14px 0}.chip{display:inline-flex;align-items:center;height:26px;padding:0 9px;border:1px solid var(--line);border-radius:999px;background:var(--panel-2);font-size:12px;color:var(--muted);font-weight:700}.inline-help{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}.toast{position:absolute;right:18px;bottom:18px;max-width:360px;padding:12px 14px;border-radius:14px;background:var(--panel);border:1px solid var(--line);box-shadow:var(--shadow);font-size:13px;color:var(--text);opacity:0;transform:translateY(8px);transition:.18s ease;pointer-events:none}.toast.show{opacity:1;transform:translateY(0)}@media(max-width:980px){.layout{grid-template-columns:230px 1fr 280px}.chart-title{width:28vw}.btn span.optional{display:none}}@media(max-width:760px){.layout{grid-template-columns:1fr}.sidebar,.props{display:none}.topbar{padding:0 10px}.chart-title{width:42vw}.floating{left:10px;bottom:10px}}
</style>
</head>
<body data-theme="dark">
<div class="app">
<header class="topbar">
<div class="brand"><div class="mark"></div><div class="title-wrap"><input id="chartTitle" class="chart-title" aria-label="Chart name"><span id="saveState" class="status">Saved</span></div></div>
<div class="top-actions"><button id="themeBtn" class="btn">Light mode</button><button id="exportBtn" class="btn primary">Generate JPEG</button></div>
</header>
<main class="layout">
<aside class="sidebar">
<section class="section"><h2>All Charts</h2><div id="chartsList" class="charts"></div><div class="divider"></div><button id="newChartBtn" class="btn primary" style="width:100%;justify-content:center">New chart</button></section>
<section class="section"><h2>Create</h2><div class="tool-grid"><button id="addNodeBtn" class="btn">Add node</button><button id="connectBtn" class="btn">Connect</button><button id="duplicateBtn" class="btn">Duplicate</button><button id="deleteBtn" class="btn danger">Delete</button></div></section>
<section class="section"><h2>Navigation</h2><p class="hint">Left-drag empty space for marquee selection. Right-click drag pans the workspace. Scroll zooms around your cursor.</p><div class="inline-help"><span class="chip"><span class="kbd">Ctrl</span>&nbsp;C copy</span><span class="chip"><span class="kbd">Ctrl</span>&nbsp;V paste</span><span class="chip"><span class="kbd">Del</span>&nbsp;delete</span></div></section>
</aside>
<section id="workspace" class="workspace"><canvas id="stage"></canvas><div class="mode-pill" id="connectHint">Connection mode: select a source node, then a target node</div><div class="floating"><span class="zoom-pill" id="zoomLabel">100%</span><span>Right-drag pan</span><span>Scroll zoom</span></div><div id="toast" class="toast"></div></section>
<aside class="props"><section class="section"><h2>Properties</h2><div id="propertyPanel"></div></section></aside>
</main>
</div>
<script>
(function(){
const storageKey="standalone-flowcharts-v1";
const themeKey="standalone-flowcharts-theme";
const canvas=document.getElementById("stage");
const ctx=canvas.getContext("2d");
const workspace=document.getElementById("workspace");
const titleInput=document.getElementById("chartTitle");
const saveState=document.getElementById("saveState");
const chartsList=document.getElementById("chartsList");
const props=document.getElementById("propertyPanel");
const zoomLabel=document.getElementById("zoomLabel");
const toast=document.getElementById("toast");
let data=loadData();
let currentId=data.currentId||data.charts[0].id;
let selectedNodes=new Set();
let selectedConnection=null;
let copied=null;
let connectMode=false;
let connectSource=null;
let pointer={down:false,button:0,last:{x:0,y:0},start:{x:0,y:0},worldStart:{x:0,y:0},dragNode:false,marquee:false,pan:false,moved:false};
let marquee=null;
let view={x:0,y:0,scale:1};
let saveTimer=null;
const dpr=Math.max(1,window.devicePixelRatio||1);
function uid(prefix){return prefix+Math.random().toString(36).slice(2,9)+Date.now().toString(36).slice(-4)}
function now(){return new Date().toISOString()}
function loadData(){
let parsed=null;
try{parsed=JSON.parse(localStorage.getItem(storageKey)||"")}catch(e){}
if(parsed&&Array.isArray(parsed.charts)&&parsed.charts.length)return parsed;
const first=sampleChart();
return{currentId:first.id,charts:[first]};
}
function sampleChart(){
const id=uid("chart-");
return{id,name:"Untitled",createdAt:now(),updatedAt:now(),nodes:[
{id:"n1",x:-250,y:-90,w:160,h:76,shape:"pill",text:"Start",fill:"#dbeafe",stroke:"#2563eb",textColor:"#0f172a",border:3},
{id:"n2",x:10,y:-100,w:174,h:96,shape:"diamond",text:"Decision",fill:"#fef3c7",stroke:"#d97706",textColor:"#111827",border:3},
{id:"n3",x:286,y:-176,w:190,h:88,shape:"square",text:"Branch A",fill:"#dcfce7",stroke:"#16a34a",textColor:"#111827",border:3},
{id:"n4",x:284,y:30,w:190,h:88,shape:"circle",text:"Branch B",fill:"#fce7f3",stroke:"#db2777",textColor:"#111827",border:3}],connections:[
{id:"c1",from:"n1",to:"n2",label:"flow",color:"#64748b",width:2},
{id:"c2",from:"n2",to:"n3",label:"yes",color:"#16a34a",width:2},
{id:"c3",from:"n2",to:"n4",label:"no",color:"#db2777",width:2}]};
}
function chart(){return data.charts.find(c=>c.id===currentId)||data.charts[0]}
function saveSoon(){saveState.textContent="Saving...";clearTimeout(saveTimer);saveTimer=setTimeout(saveNow,170)}
function saveNow(){const c=chart();if(c)c.updatedAt=now();data.currentId=currentId;localStorage.setItem(storageKey,JSON.stringify(data));saveState.textContent="Saved";renderCharts()}
function uniqueName(base,excludeId){let clean=(base||"").trim()||"Untitled";const names=data.charts.filter(c=>c.id!==excludeId).map(c=>c.name.toLowerCase());if(!names.includes(clean.toLowerCase()))return clean;const stripped=clean.replace(/\s\(\d+\)$/i,"");let i=2;while(names.includes((stripped+" ("+i+")").toLowerCase()))i++;return stripped+" ("+i+")"}
function nextUntitled(){const names=data.charts.map(c=>c.name.toLowerCase());if(!names.includes("untitled"))return"Untitled";let i=2;while(names.includes(("Untitled "+i).toLowerCase()))i++;return"Untitled "+i}
function setTheme(theme){document.body.dataset.theme=theme;localStorage.setItem(themeKey,theme);document.getElementById("themeBtn").textContent=theme==="dark"?"Light mode":"Dark mode";draw()}
setTheme(localStorage.getItem(themeKey)||"dark");
function renderCharts(){chartsList.innerHTML="";data.charts.slice().sort((a,b)=>new Date(b.updatedAt)-new Date(a.updatedAt)).forEach(c=>{const row=document.createElement("div");row.className="chart-row"+(c.id===currentId?" active":"");const left=document.createElement("div");left.innerHTML="<div class='chart-name'></div><div class='chart-meta'></div>";left.querySelector(".chart-name").textContent=c.name;left.querySelector(".chart-meta").textContent=c.nodes.length+" nodes · "+c.connections.length+" links";left.onclick=()=>switchChart(c.id);const actions=document.createElement("div");actions.className="mini-actions";const copy=mini("⧉","Duplicate chart",()=>duplicateChart(c.id));const del=mini("×","Delete chart",()=>deleteChart(c.id));actions.append(copy,del);row.append(left,actions);chartsList.append(row)})}
function mini(txt,label,fn){const b=document.createElement("button");b.className="icon-btn";b.textContent=txt;b.title=label;b.onclick=e=>{e.stopPropagation();fn()};return b}
function switchChart(id){currentId=id;selectedNodes.clear();selectedConnection=null;connectMode=false;connectSource=null;fitView(false);syncUI();saveNow();draw()}
function duplicateChart(id){const source=data.charts.find(c=>c.id===id);if(!source)return;const clone=JSON.parse(JSON.stringify(source));clone.id=uid("chart-");clone.name=uniqueName(source.name,clone.id);clone.createdAt=now();clone.updatedAt=now();data.charts.push(clone);currentId=clone.id;selectedNodes.clear();selectedConnection=null;syncUI();saveNow();draw();showToast("Chart duplicated")}
function deleteChart(id){if(data.charts.length===1){showToast("At least one chart is required");return}const c=data.charts.find(x=>x.id===id);if(!c||!confirm("Delete “"+c.name+"”?"))return;data.charts=data.charts.filter(x=>x.id!==id);if(currentId===id)currentId=data.charts[0].id;selectedNodes.clear();selectedConnection=null;syncUI();saveNow();draw()}
function newChart(){const c={id:uid("chart-"),name:nextUntitled(),createdAt:now(),updatedAt:now(),nodes:[],connections:[]};data.charts.push(c);currentId=c.id;selectedNodes.clear();selectedConnection=null;view={x:canvas.clientWidth/2,y:canvas.clientHeight/2,scale:1};syncUI();saveNow();draw()}
function syncUI(){const c=chart();titleInput.value=c.name;workspace.classList.toggle("connecting",connectMode);renderCharts();renderProps();zoomLabel.textContent=Math.round(view.scale*100)+"%"}
function renderProps(){const c=chart();const nodes=[...selectedNodes].map(id=>c.nodes.find(n=>n.id===id)).filter(Boolean);const conn=selectedConnection?c.connections.find(x=>x.id===selectedConnection):null;if(nodes.length===1){const n=nodes[0];props.innerHTML="<div class='field'><label>Text</label><textarea id='pText'></textarea></div><div class='field'><label>Shape</label><select id='pShape'><option value='square'>Square</option><option value='circle'>Circle</option><option value='diamond'>Diamond</option><option value='pill'>Pill</option></select></div><div class='row'><div class='field'><label>Width</label><input id='pW' type='number' min='50'></div><div class='field'><label>Height</label><input id='pH' type='number' min='40'></div></div><div class='row'><div class='field'><label>Fill</label><input id='pFill' type='color'></div><div class='field'><label>Border</label><input id='pStroke' type='color'></div></div><div class='row'><div class='field'><label>Text color</label><input id='pTextColor' type='color'></div><div class='field'><label>Border thickness</label><input id='pBorder' type='number' min='1' max='16'></div></div><button id='focusBtn' class='btn' style='width:100%;justify-content:center'>Center selection</button>";setVal("pText",n.text);setVal("pShape",n.shape);setVal("pW",n.w);setVal("pH",n.h);setVal("pFill",n.fill);setVal("pStroke",n.stroke);setVal("pTextColor",n.textColor);setVal("pBorder",n.border);bind("pText","input",v=>n.text=v);bind("pShape","change",v=>n.shape=v);bind("pW","input",v=>n.w=Math.max(50,+v||50));bind("pH","input",v=>n.h=Math.max(40,+v||40));bind("pFill","input",v=>n.fill=v);bind("pStroke","input",v=>n.stroke=v);bind("pTextColor","input",v=>n.textColor=v);bind("pBorder","input",v=>n.border=Math.max(1,Math.min(16,+v||1)));document.getElementById("focusBtn").onclick=()=>centerOnNodes(nodes);return}
if(nodes.length>1){props.innerHTML="<div class='empty'>"+nodes.length+" nodes selected. Drag any selected node to move the group, or use copy, paste, duplicate, and delete shortcuts.</div><div class='divider'></div><div class='row'><div class='field'><label>Fill</label><input id='mFill' type='color' value='#dbeafe'></div><div class='field'><label>Border</label><input id='mStroke' type='color' value='#2563eb'></div></div><button id='centerMulti' class='btn' style='width:100%;justify-content:center'>Center selection</button>";bindMulti("mFill","input",v=>nodes.forEach(n=>n.fill=v));bindMulti("mStroke","input",v=>nodes.forEach(n=>n.stroke=v));document.getElementById("centerMulti").onclick=()=>centerOnNodes(nodes);return}
if(conn){props.innerHTML="<div class='field'><label>Line label</label><input id='cLabel'></div><div class='row'><div class='field'><label>Line color</label><input id='cColor' type='color'></div><div class='field'><label>Line width</label><input id='cWidth' type='number' min='1' max='12'></div></div><button id='reverseConn' class='btn' style='width:100%;justify-content:center'>Reverse direction</button>";setVal("cLabel",conn.label||"");setVal("cColor",conn.color||"#64748b");setVal("cWidth",conn.width||2);bind("cLabel","input",v=>conn.label=v,true);bind("cColor","input",v=>conn.color=v,true);bind("cWidth","input",v=>conn.width=Math.max(1,Math.min(12,+v||1)),true);document.getElementById("reverseConn").onclick=()=>{const t=conn.from;conn.from=conn.to;conn.to=t;saveSoon();draw()};return}
props.innerHTML="<div class='empty'>Select a node to edit its shape, border, colors, size, and text. Select a line to edit its label and style.</div>"}
function setVal(id,v){document.getElementById(id).value=v}
function bind(id,event,fn,isConn){document.getElementById(id).addEventListener(event,e=>{fn(e.target.value);saveSoon();renderProps();draw()},{once:false});if(isConn){}
}
function bindMulti(id,event,fn){document.getElementById(id).addEventListener(event,e=>{fn(e.target.value);saveSoon();draw()})}
function addNode(x,y){const p=x==null?screenToWorld(canvas.clientWidth/2,canvas.clientHeight/2):{x,y};const palette=["#dbeafe","#dcfce7","#fef3c7","#fce7f3","#ede9fe"];const strokes=["#2563eb","#16a34a","#d97706","#db2777","#7c3aed"];const i=chart().nodes.length%palette.length;const n={id:uid("n-"),x:p.x-85,y:p.y-42,w:170,h:84,shape:"square",text:"New node",fill:palette[i],stroke:strokes[i],textColor:"#111827",border:3};chart().nodes.push(n);selectedNodes=new Set([n.id]);selectedConnection=null;saveSoon();syncUI();draw()}
function createConnection(from,to){if(from===to)return;const label=prompt("Connection label","")||"";chart().connections.push({id:uid("c-"),from,to,label,color:"#64748b",width:2});selectedNodes.clear();selectedConnection=null;connectMode=false;connectSource=null;saveSoon();syncUI();draw()}
function duplicateSelection(){copySelection();pasteSelection()}
function copySelection(){const c=chart();const ids=[...selectedNodes];if(!ids.length)return;const nodes=c.nodes.filter(n=>selectedNodes.has(n.id)).map(n=>({...n}));const connections=c.connections.filter(e=>selectedNodes.has(e.from)&&selectedNodes.has(e.to)).map(e=>({...e}));copied={nodes,connections};showToast(nodes.length+" node"+(nodes.length===1?"":"s")+" copied")}
function pasteSelection(){if(!copied||!copied.nodes.length)return;const c=chart();const map=new Map();const newNodes=copied.nodes.map(n=>{const id=uid("n-");map.set(n.id,id);return{...n,id,x:n.x+34,y:n.y+34}});const newConnections=copied.connections.map(e=>({...e,id:uid("c-"),from:map.get(e.from),to:map.get(e.to)})).filter(e=>e.from&&e.to);c.nodes.push(...newNodes);c.connections.push(...newConnections);selectedNodes=new Set(newNodes.map(n=>n.id));selectedConnection=null;copied={nodes:newNodes.map(n=>({...n})),connections:newConnections.map(e=>({...e}))};saveSoon();syncUI();draw();showToast("Pasted")}
function deleteSelection(){const c=chart();if(selectedNodes.size){c.nodes=c.nodes.filter(n=>!selectedNodes.has(n.id));c.connections=c.connections.filter(e=>!selectedNodes.has(e.from)&&!selectedNodes.has(e.to));selectedNodes.clear()}else if(selectedConnection){c.connections=c.connections.filter(e=>e.id!==selectedConnection);selectedConnection=null}else{return}saveSoon();syncUI();draw()}
function resizeCanvas(){const r=canvas.getBoundingClientRect();canvas.width=Math.max(1,Math.floor(r.width*dpr));canvas.height=Math.max(1,Math.floor(r.height*dpr));ctx.setTransform(dpr,0,0,dpr,0,0);draw()}
function screenToWorld(x,y){return{x:(x-view.x)/view.scale,y:(y-view.y)/view.scale}}
function worldToScreen(x,y){return{x:x*view.scale+view.x,y:y*view.scale+view.y}}
function fitView(animate){const c=chart();if(!c.nodes.length){view={x:canvas.clientWidth/2,y:canvas.clientHeight/2,scale:1};return}const b=bounds(c.nodes);const s=Math.min(1.25,Math.max(.25,Math.min((canvas.clientWidth-140)/b.w,(canvas.clientHeight-140)/b.h)));view.scale=s;view.x=canvas.clientWidth/2-(b.x+b.w/2)*s;view.y=canvas.clientHeight/2-(b.y+b.h/2)*s;zoomLabel.textContent=Math.round(view.scale*100)+"%"}
function bounds(nodes){let minX=Infinity,minY=Infinity,maxX=-Infinity,maxY=-Infinity;nodes.forEach(n=>{minX=Math.min(minX,n.x);minY=Math.min(minY,n.y);maxX=Math.max(maxX,n.x+n.w);maxY=Math.max(maxY,n.y+n.h)});return{x:minX,y:minY,w:maxX-minX||1,h:maxY-minY||1}}
function centerOnNodes(nodes){if(!nodes.length)return;const b=bounds(nodes);view.x=canvas.clientWidth/2-(b.x+b.w/2)*view.scale;view.y=canvas.clientHeight/2-(b.y+b.h/2)*view.scale;syncUI();draw()}
function draw(){ctx.save();ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,canvas.clientWidth,canvas.clientHeight);drawScene(ctx,false);ctx.restore();zoomLabel.textContent=Math.round(view.scale*100)+"%"}
function drawScene(g,exporting){const c=chart();if(!exporting)drawGrid(g);g.save();g.translate(view.x,view.y);g.scale(view.scale,view.scale);c.connections.forEach(e=>drawConnection(g,e,exporting));c.nodes.forEach(n=>drawNode(g,n,exporting));if(marquee&&!exporting)drawMarquee(g);g.restore()}
function drawGrid(g){g.fillStyle=getCss("--canvas");g.fillRect(0,0,canvas.clientWidth,canvas.clientHeight);const step=36*view.scale;const ox=((view.x%step)+step)%step;const oy=((view.y%step)+step)%step;g.strokeStyle=getCss("--grid");g.lineWidth=1;g.beginPath();for(let x=ox;x<canvas.clientWidth;x+=step){g.moveTo(x,0);g.lineTo(x,canvas.clientHeight)}for(let y=oy;y<canvas.clientHeight;y+=step){g.moveTo(0,y);g.lineTo(canvas.clientWidth,y)}g.stroke()}
function getCss(v){return getComputedStyle(document.body).getPropertyValue(v).trim()}
function drawNode(g,n,exporting){g.save();pathNode(g,n);g.fillStyle=n.fill;g.fill();g.lineWidth=n.border;g.strokeStyle=n.stroke;g.stroke();if(selectedNodes.has(n.id)&&!exporting){g.lineWidth=2/view.scale;g.strokeStyle=getCss("--selected");g.setLineDash([7/view.scale,5/view.scale]);pathNode(g,{...n,x:n.x-6/view.scale,y:n.y-6/view.scale,w:n.w+12/view.scale,h:n.h+12/view.scale});g.stroke();g.setLineDash([])}g.clip();g.fillStyle=n.textColor;g.textAlign="center";g.textBaseline="middle";g.font="700 15px Inter, system-ui, sans-serif";wrapText(g,n.text,n.x+n.w/2,n.y+n.h/2,n.w-28,20);g.restore()}
function pathNode(g,n){const r=Math.min(n.h/2,32);g.beginPath();if(n.shape==="circle"){g.ellipse(n.x+n.w/2,n.y+n.h/2,n.w/2,n.h/2,0,0,Math.PI*2)}else if(n.shape==="diamond"){g.moveTo(n.x+n.w/2,n.y);g.lineTo(n.x+n.w,n.y+n.h/2);g.lineTo(n.x+n.w/2,n.y+n.h);g.lineTo(n.x,n.y+n.h/2);g.closePath()}else if(n.shape==="pill"){roundRect(g,n.x,n.y,n.w,n.h,n.h/2)}else{roundRect(g,n.x,n.y,n.w,n.h,10)}}
function roundRect(g,x,y,w,h,r){r=Math.min(r,w/2,h/2);g.moveTo(x+r,y);g.lineTo(x+w-r,y);g.quadraticCurveTo(x+w,y,x+w,y+r);g.lineTo(x+w,y+h-r);g.quadraticCurveTo(x+w,y+h,x+w-r,y+h);g.lineTo(x+r,y+h);g.quadraticCurveTo(x,y+h,x,y+h-r);g.lineTo(x,y+r);g.quadraticCurveTo(x,y,x+r,y)}
function wrapText(g,text,x,y,maxWidth,lineHeight){const words=(text||"").split(/\s+/);let lines=[""],line="";words.forEach(word=>{const test=line?line+" "+word:word;if(g.measureText(test).width>maxWidth&&line){lines.push(word);line=word}else{lines[lines.length-1]=test;line=test}});const start=y-(lines.length-1)*lineHeight/2;lines.slice(0,5).forEach((l,i)=>g.fillText(l,x,start+i*lineHeight))}
function drawConnection(g,e,exporting){const c=chart();const a=c.nodes.find(n=>n.id===e.from),b=c.nodes.find(n=>n.id===e.to);if(!a||!b)return;const p1=anchor(a,b.x+b.w/2,b.y+b.h/2),p2=anchor(b,a.x+a.w/2,a.y+a.h/2);const dx=Math.abs(p2.x-p1.x);const cp=Math.max(50,dx*.42);g.save();g.strokeStyle=e.color||"#64748b";g.lineWidth=e.width||2;g.lineCap="round";g.lineJoin="round";if(selectedConnection===e.id&&!exporting){g.shadowColor=getCss("--selected");g.shadowBlur=8/view.scale}g.beginPath();g.moveTo(p1.x,p1.y);g.bezierCurveTo(p1.x+Math.sign(p2.x-p1.x||1)*cp,p1.y,p2.x-Math.sign(p2.x-p1.x||1)*cp,p2.y,p2.x,p2.y);g.stroke();drawArrow(g,p1,p2,e.color||"#64748b",e.width||2);if(e.label){const m=bezierPoint(p1,{x:p1.x+Math.sign(p2.x-p1.x||1)*cp,y:p1.y},{x:p2.x-Math.sign(p2.x-p1.x||1)*cp,y:p2.y},p2,.5);g.font="700 13px Inter, system-ui, sans-serif";const tw=g.measureText(e.label).width;g.fillStyle=document.body.dataset.theme==="dark"?"#111827":"#ffffff";g.strokeStyle=e.color||"#64748b";g.lineWidth=1.5;roundRect(g,m.x-tw/2-10,m.y-14,tw+20,28,9);g.fill();g.stroke();g.fillStyle=document.body.dataset.theme==="dark"?"#eef2ff":"#111827";g.textAlign="center";g.textBaseline="middle";g.fillText(e.label,m.x,m.y+1)}g.restore()}
function drawArrow(g,p1,p2,color,width){const ang=Math.atan2(p2.y-p1.y,p2.x-p1.x);const size=10+width;g.fillStyle=color;g.beginPath();g.moveTo(p2.x,p2.y);g.lineTo(p2.x-Math.cos(ang-.45)*size,p2.y-Math.sin(ang-.45)*size);g.lineTo(p2.x-Math.cos(ang+.45)*size,p2.y-Math.sin(ang+.45)*size);g.closePath();g.fill()}
function bezierPoint(p0,p1,p2,p3,t){const mt=1-t;return{x:mt*mt*mt*p0.x+3*mt*mt*t*p1.x+3*mt*t*t*p2.x+t*t*t*p3.x,y:mt*mt*mt*p0.y+3*mt*mt*t*p1.y+3*mt*t*t*p2.y+t*t*t*p3.y}}
function anchor(n,tx,ty){const cx=n.x+n.w/2,cy=n.y+n.h/2,dx=tx-cx,dy=ty-cy;if(n.shape==="square"){return{x:dx>=0?n.x+n.w:n.x,y:dy>=0?n.y+n.h:n.y}}if(Math.abs(dx)>Math.abs(dy))return{x:dx>=0?n.x+n.w:n.x,y:cy};return{x:cx,y:dy>=0?n.y+n.h:n.y}}
function drawMarquee(g){const x=Math.min(marquee.x1,marquee.x2),y=Math.min(marquee.y1,marquee.y2),w=Math.abs(marquee.x2-marquee.x1),h=Math.abs(marquee.y2-marquee.y1);g.fillStyle=getCss("--marquee");g.strokeStyle=getCss("--marquee-border");g.lineWidth=1/view.scale;g.setLineDash([6/view.scale,5/view.scale]);g.fillRect(x,y,w,h);g.strokeRect(x,y,w,h);g.setLineDash([])}
function hitNode(p){const nodes=chart().nodes;for(let i=nodes.length-1;i>=0;i--){const n=nodes[i];const cx=n.x+n.w/2,cy=n.y+n.h/2,rx=n.w/2,ry=n.h/2,dx=p.x-cx,dy=p.y-cy;if(n.shape==="diamond"){if(Math.abs(dx)/rx+Math.abs(dy)/ry<=1)return n}else if(n.shape==="circle"){if((dx*dx)/(rx*rx)+(dy*dy)/(ry*ry)<=1)return n}else{if(p.x>=n.x&&p.x<=n.x+n.w&&p.y>=n.y&&p.y<=n.y+n.h)return n}}return null}
function hitConnection(p){const c=chart();let best=null,dist=10/view.scale;c.connections.forEach(e=>{const a=c.nodes.find(n=>n.id===e.from),b=c.nodes.find(n=>n.id===e.to);if(!a||!b)return;const p1=anchor(a,b.x+b.w/2,b.y+b.h/2),p2=anchor(b,a.x+a.w/2,a.y+a.h/2);let last=p1;for(let i=1;i<=24;i++){const t=i/24;const dx=Math.abs(p2.x-p1.x);const cp=Math.max(50,dx*.42);const pt=bezierPoint(p1,{x:p1.x+Math.sign(p2.x-p1.x||1)*cp,y:p1.y},{x:p2.x-Math.sign(p2.x-p1.x||1)*cp,y:p2.y},p2,t);const d=distToSegment(p,last,pt);if(d<dist){dist=d;best=e}last=pt}});return best}
function distToSegment(p,a,b){const dx=b.x-a.x,dy=b.y-a.y,l=dx*dx+dy*dy;if(!l)return Math.hypot(p.x-a.x,p.y-a.y);let t=((p.x-a.x)*dx+(p.y-a.y)*dy)/l;t=Math.max(0,Math.min(1,t));return Math.hypot(p.x-(a.x+t*dx),p.y-(a.y+t*dy))}
canvas.addEventListener("contextmenu",e=>e.preventDefault());
canvas.addEventListener("pointerdown",e=>{canvas.setPointerCapture(e.pointerId);pointer={down:true,button:e.button,last:{x:e.clientX,y:e.clientY},start:{x:e.clientX,y:e.clientY},worldStart:screenToWorld(e.offsetX,e.offsetY),dragNode:false,marquee:false,pan:false,moved:false};if(e.button===2){pointer.pan=true;workspace.classList.add("panning");return}const p=screenToWorld(e.offsetX,e.offsetY);const n=hitNode(p);if(connectMode){if(n){if(!connectSource){connectSource=n.id;showToast("Source selected. Choose a target node.")}else{createConnection(connectSource,n.id)}}return}if(n){if(e.shiftKey){selectedNodes.has(n.id)?selectedNodes.delete(n.id):selectedNodes.add(n.id)}else if(!selectedNodes.has(n.id)){selectedNodes=new Set([n.id])}selectedConnection=null;pointer.dragNode=true;syncUI();draw()}else{const edge=hitConnection(p);if(edge){selectedNodes.clear();selectedConnection=edge.id;syncUI();draw()}else{selectedNodes.clear();selectedConnection=null;pointer.marquee=true;marquee={x1:p.x,y1:p.y,x2:p.x,y2:p.y};syncUI();draw()}}});
canvas.addEventListener("pointermove",e=>{if(!pointer.down)return;const dx=e.clientX-pointer.last.x,dy=e.clientY-pointer.last.y;if(Math.abs(e.clientX-pointer.start.x)+Math.abs(e.clientY-pointer.start.y)>3)pointer.moved=true;if(pointer.pan){view.x+=dx;view.y+=dy;pointer.last={x:e.clientX,y:e.clientY};draw();return}const p=screenToWorld(e.offsetX,e.offsetY);if(pointer.dragNode){const wdx=dx/view.scale,wdy=dy/view.scale;chart().nodes.forEach(n=>{if(selectedNodes.has(n.id)){n.x+=wdx;n.y+=wdy}});pointer.last={x:e.clientX,y:e.clientY};saveSoon();draw();return}if(pointer.marquee&&marquee){marquee.x2=p.x;marquee.y2=p.y;const x=Math.min(marquee.x1,marquee.x2),y=Math.min(marquee.y1,marquee.y2),w=Math.abs(marquee.x2-marquee.x1),h=Math.abs(marquee.y2-marquee.y1);selectedNodes=new Set(chart().nodes.filter(n=>n.x+n.w>=x&&n.x<=x+w&&n.y+n.h>=y&&n.y<=y+h).map(n=>n.id));selectedConnection=null;draw()}});
canvas.addEventListener("pointerup",e=>{pointer.down=false;workspace.classList.remove("panning");if(pointer.marquee){marquee=null;syncUI();draw()}});
canvas.addEventListener("wheel",e=>{e.preventDefault();const rect=canvas.getBoundingClientRect();const sx=e.clientX-rect.left,sy=e.clientY-rect.top;const before=screenToWorld(sx,sy);const factor=e.deltaY<0?1.09:.92;view.scale=Math.max(.15,Math.min(3.5,view.scale*factor));view.x=sx-before.x*view.scale;view.y=sy-before.y*view.scale;syncUI();draw()},{passive:false});
document.addEventListener("keydown",e=>{const mod=e.ctrlKey||e.metaKey;if(mod&&e.key.toLowerCase()==="c"){e.preventDefault();copySelection()}else if(mod&&e.key.toLowerCase()==="v"){e.preventDefault();pasteSelection()}else if(mod&&e.key.toLowerCase()==="d"){e.preventDefault();duplicateSelection()}else if(mod&&e.key.toLowerCase()==="s"){e.preventDefault();saveNow();showToast("Saved locally")}else if(e.key==="Delete"||e.key==="Backspace"){if(document.activeElement&&["INPUT","TEXTAREA","SELECT"].includes(document.activeElement.tagName))return;e.preventDefault();deleteSelection()}else if(e.key==="Escape"){connectMode=false;connectSource=null;marquee=null;syncUI();draw()}else if((e.key==="+"||e.key==="=")&&!document.activeElement.matches("input,textarea")){view.scale=Math.min(3.5,view.scale*1.12);syncUI();draw()}else if(e.key==="-"&&!document.activeElement.matches("input,textarea")){view.scale=Math.max(.15,view.scale*.88);syncUI();draw()}});
titleInput.addEventListener("blur",()=>{const c=chart();c.name=uniqueName(titleInput.value,c.id);titleInput.value=c.name;saveNow();renderCharts()});
titleInput.addEventListener("keydown",e=>{if(e.key==="Enter")titleInput.blur()});
document.getElementById("newChartBtn").onclick=newChart;
document.getElementById("addNodeBtn").onclick=()=>addNode();
document.getElementById("connectBtn").onclick=()=>{connectMode=!connectMode;connectSource=null;syncUI();draw();showToast(connectMode?"Connection mode enabled":"Connection mode disabled")};
document.getElementById("duplicateBtn").onclick=duplicateSelection;
document.getElementById("deleteBtn").onclick=deleteSelection;
document.getElementById("themeBtn").onclick=()=>setTheme(document.body.dataset.theme==="dark"?"light":"dark");
document.getElementById("exportBtn").onclick=exportJpeg;
function exportJpeg(){const c=chart();if(!c.nodes.length){showToast("Add at least one node before exporting");return}const b=bounds(c.nodes),pad=90,w=Math.ceil(b.w+pad*2),h=Math.ceil(b.h+pad*2),scale=2;const out=document.createElement("canvas");out.width=w*scale;out.height=h*scale;const g=out.getContext("2d");g.scale(scale,scale);g.fillStyle=document.body.dataset.theme==="dark"?"#0e1726":"#eef3fa";g.fillRect(0,0,w,h);g.translate(-b.x+pad,-b.y+pad);const oldView={...view};view={x:0,y:0,scale:1};c.connections.forEach(e=>drawConnection(g,e,true));c.nodes.forEach(n=>drawNode(g,n,true));view=oldView;const a=document.createElement("a");a.href=out.toDataURL("image/jpeg",.94);a.download=(c.name||"flowchart").replace(/[^a-z0-9-_]+/gi,"-").replace(/^-|-$/g,"").toLowerCase()+".jpg";a.click();showToast("JPEG generated")}
function showToast(msg){toast.textContent=msg;toast.classList.add("show");clearTimeout(showToast.t);showToast.t=setTimeout(()=>toast.classList.remove("show"),2200)}
window.addEventListener("resize",resizeCanvas);
resizeCanvas();fitView(false);syncUI();draw();saveNow();
})();
</script>
</html>
